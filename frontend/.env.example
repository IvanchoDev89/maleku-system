# ============================================
# Costa Rica Travel - Frontend Environment
# Copy this to .env and fill with real values
# ============================================

# API Configuration
NUXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_ENVIRONMENT=development

# Stripe (optional)
NUXT_PUBLIC_STRIPE_KEY=pk_test_your_key

# Sentry (optional)
NUXT_PUBLIC_SENTRY_DSN=

# CDN URL (optional, for Cloudinary images)
# NUXT_PUBLIC_CDN_URL=https://res.cloudinary.com/your-cloud
