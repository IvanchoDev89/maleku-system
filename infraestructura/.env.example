# Database Configuration
DB_USER=crtravel
DB_PASSWORD=change-this-secure-password-in-production
DB_NAME=costaricatravel
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=change-this-secure-password-in-production
REDIS_PORT=6379

# API Configuration
API_PORT=8000
DEBUG=false

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=generate-a-secure-random-key-here-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Stripe (get from Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend
FRONTEND_DIR=../frontend
WEB_PORT=3000

# Backend
BACKEND_DIR=../backend

# Nginx
HTTP_PORT=80
HTTPS_PORT=443

# Network
NETWORK_SUBNET=172.20.0.0/16

# Site URL
SITE_URL=https://costaricatravel.dev
