# ============================================
# Costa Rica Travel - Production Environment
# Copy this to .env and fill with real values
# ============================================

# Application
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=your-super-secret-key-min-32-chars-long
SITE_URL=https://your-frontend-url.vercel.app

# Database - Railway PostgreSQL
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@your-railway-db-url.railway.internal:5432/railway
POSTGRES_PORT=5432

# Redis - Railway Redis
# Format: redis://default:password@host:port/0
REDIS_URL=redis://default:password@your-redis-url.cache.amazonaws.com:6379/0
REDIS_PORT=6379

# Email - Resend
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Costa Rica Travel <noreply@costaricatravel.dev>
EMAIL_ENABLED=true

# Cloudinary - Image uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Stripe - Payments (optional)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS - Frontend URL
BACKEND_CORS_ORIGINS=https://your-frontend-url.vercel.app,https://www.your-domain.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Seed default password (set for dev, required in production without DEBUG)
# SEED_DEFAULT_PASSWORD=YourSeedPassword123!

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
